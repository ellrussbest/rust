#!/bin/bash

if [ -z "$1" ]; then
    echo "Usage:"
    echo "  ./run lesson <number>"
    echo "  ./run <bin>"
    exit 1
fi

COMMAND=$1

# Ensure cargo exists
if ! command -v cargo &> /dev/null; then
    echo "Cargo not found. Installing Rust..."
    curl https://sh.rustup.rs -sSf | sh -s -- -y
    source "$HOME/.cargo/env"
fi

# Handle "lesson" command
if [ "$COMMAND" = "lesson" ]; then
    if [ -z "$2" ]; then
        echo "Usage: ./run lesson <number>"
        exit 1
    fi

    LESSON_NUM=$2
    BIN_NAME="${LESSON_NUM}"

else
    BIN_NAME=$COMMAND
fi

# Run the binary
cargo run -p rusty --bin "$BIN_NAME"